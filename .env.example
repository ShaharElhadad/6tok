# Copy this file to .env.local and fill in.
# After changing .env.local you MUST restart `npm run dev`.
#
# For the system to work end-to-end you need ONE transcription option + ONE analysis option.

# ============================================================================
# 1) TRANSCRIPTION — pick one (priority order in code: local → groq → openai)
# ============================================================================

# ---- LOCAL WhisperX (production — free, unlimited size, strongest) ----
# Start: cd whisper-server && pip install -r requirements.txt && uvicorn server:app --port 8787
# WHISPER_URL=http://127.0.0.1:8787

# ---- Groq — FREE tier, whisper-large-v3, 25MB limit, very fast ----
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
# Optional overrides:
# GROQ_WHISPER_MODEL=whisper-large-v3          # or whisper-large-v3-turbo
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- OpenAI — paid, whisper-1, 25MB limit ----
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# WHISPER_MODEL=whisper-1

# ============================================================================
# 2) ANALYSIS (LLM) — pick one (Claude preferred; Gemini is free fallback)
# ============================================================================

# ---- Anthropic Claude (best quality) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---- Google Gemini (FREE tier) ----
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Force a provider even if both keys are set:
# LLM_PROVIDER=anthropic   # or: gemini

# ============================================================================
# 3) Misc
# ============================================================================
MAX_UPLOAD_MB=500
PUBLIC_BASE_URL=http://127.0.0.1:3300
